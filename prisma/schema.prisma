generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  CENTER_ADMIN
  SUPER_ADMIN
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINAL
}

enum Stage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

model GarrinchaCenter {
  id              String          @id @default(cuid())
  name            String          @unique
  country         String
  city            String
  bannerUrl       String?
  activatedUsers  User[]          @relation("ActivationCenter")
  competingUsers  User[]          @relation("CompetitionCenter")
  sessions        CenterSession[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model User {
  id                          String            @id @default(cuid())
  email                       String            @unique
  passwordHash                String?
  fullName                    String
  nickname                    String            @unique
  dateOfBirth                 DateTime?
  phoneNumber                 String
  displayName                 String?
  nationality                 String?
  role                        Role              @default(USER)
  centerId                    String
  center                      GarrinchaCenter   @relation("ActivationCenter", fields: [centerId], references: [id])
  firstActivatedAt            DateTime?
  competitionCenterId         String?
  competitionCenter           GarrinchaCenter?  @relation("CompetitionCenter", fields: [competitionCenterId], references: [id])
  competitionCenterLockedAt   DateTime?
  avatarUrl                   String?
  accessTokenHash             String?
  accessTokenCreatedAt        DateTime?
  accessTokenRevokedAt        DateTime?
  lastAccessLinkSentAt        DateTime?
  predictions                 Prediction[]
  pointEvents                 PointEvent[]
  checkIn                     CenterCheckIn?
  centerChangeLogs            CenterChangeLog[]
  activationCodeClaims        ActivationCodeClaim[]
  dailyBonusClaims            DailyBonusClaim[]
  checkInClaims               CheckInClaim[]
  emailUnsubscribedAt         DateTime?
  invitationJob               InvitationJob?
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt

  @@index([accessTokenHash])
  @@index([centerId])
  @@index([competitionCenterId])
  @@index([nationality])
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  fifaCode  String   @unique
  flagUrl   String
  groupName String?
  homeGames Match[]  @relation("HomeTeam")
  awayGames Match[]  @relation("AwayTeam")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id                String       @id @default(cuid())
  fifaMatchNo       Int?         @unique
  stage             Stage
  venue             String
  kickoffAt         DateTime
  status            MatchStatus  @default(SCHEDULED)
  homeTeamId        String
  homeTeam          Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId        String
  awayTeam          Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore         Int?
  awayScore         Int?
  finalizedAt       DateTime?
  scoreSource       String?
  externalMatchId   String?
  externalUpdatedAt DateTime?
  scoreSyncStatus   String?
  lastScoreSyncAt   DateTime?
  pendingHomeScore  Int?
  pendingAwayScore  Int?
  wentToPenalties   Boolean      @default(false)
  penaltyWinner     String?
  homePenaltyScore  Int?
  awayPenaltyScore  Int?
  predictions       Prediction[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([kickoffAt])
  @@index([stage])
  @@index([status])
}

model Prediction {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId       String
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeScore        Int
  awayScore        Int
  penaltyWinner    String?
  homePenaltyScore Int?
  awayPenaltyScore Int?
  pointsAwarded    Int       @default(0)
  calculatedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model PointEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points    Int
  reason    String
  awardedBy String?
  matchId   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model CenterSession {
  id        String                @id @default(cuid())
  centerId  String
  center    GarrinchaCenter       @relation(fields: [centerId], references: [id])
  code      String                @unique
  expiresAt DateTime
  createdBy String
  createdAt DateTime              @default(now())
  claims    ActivationCodeClaim[]

  @@index([centerId])
  @@index([expiresAt])
}

model CenterCheckIn {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  centerId  String
  sessionId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model CenterChangeLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromCenterId String?
  toCenterId   String
  changedBy    String
  changeType   String
  createdAt    DateTime @default(now())

  @@index([userId])
}

model ActivationCodeClaim {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  session   CenterSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  claimedAt DateTime      @default(now())

  @@unique([userId, sessionId])
  @@index([userId])
}

model DailyBonusCode {
  id               String            @id @default(cuid())
  code             String
  bonusDate        String
  points           Int               @default(3)
  createdByAdminId String
  createdAt        DateTime          @default(now())
  expiresAt        DateTime
  isActive         Boolean           @default(true)
  claims           DailyBonusClaim[]

  @@index([bonusDate, isActive])
  @@index([code])
}

model DailyBonusClaim {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyBonusCodeId String
  code             DailyBonusCode @relation(fields: [dailyBonusCodeId], references: [id], onDelete: Cascade)
  bonusDate        String
  pointsAwarded    Int            @default(3)
  claimedAt        DateTime       @default(now())

  @@unique([userId, bonusDate])
  @@index([userId])
  @@index([bonusDate])
}

model CheckInCode {
  id              String       @id @default(cuid())
  code            String
  date            String
  expiresAt       DateTime
  createdByUserId String
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  claims          CheckInClaim[]

  @@index([code, isActive])
  @@index([date])
}

model CheckInClaim {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkInCodeId String
  checkInCode   CheckInCode @relation(fields: [checkInCodeId], references: [id], onDelete: Cascade)
  date          String
  pointsAwarded Int         @default(3)
  claimedAt     DateTime    @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model InvitationJob {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String    @unique
  displayName String
  centerName  String
  importRunId String?
  status      String    @default("pending")
  attempts    Int       @default(0)
  lastError   String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([importRunId])
}

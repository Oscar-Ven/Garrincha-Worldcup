# Normalise line endings to LF in the repo; Git converts on checkout for Windows.
* text=auto eol=lf

# Source files — always LF
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.md      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.sql     text eol=lf
*.prisma  text eol=lf
*.env*    text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# SVG — text but keep LF
*.svg     text eol=lf

# Binary — never diff or convert
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary
*.mp4     binary
*.pdf     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.zip     binary

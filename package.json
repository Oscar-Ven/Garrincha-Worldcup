{
  "name": "garrincha-world-cup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "video:demo": "node scripts/render-demo-video.mjs",
    "env:check": "node scripts/check-supabase-env.mjs",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node --env-file=.env --import tsx/esm prisma/seed.ts",
    "load:local": "node scripts/load-test.mjs",
    "qa:players:mobile": "node scripts/qa-players-mobile.mjs",
    "qa:owner:desktop": "node scripts/qa-owner-desktop.mjs",
    "flags:refresh": "npx tsx --env-file=.env scripts/refresh-flags.ts",
    "flags:refresh:force": "npx tsx --env-file=.env scripts/refresh-flags.ts --force"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sentry/nextjs": "^10.56.0",
    "@tailwindcss/postcss": "^4.3.0",
    "bcryptjs": "3.0.3",
    "jose": "6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "pg": "8.21.0",
    "prisma": "7.8.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "^4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.6",
    "ffmpeg-static": "^5.3.0",
    "playwright": "^1.60.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}

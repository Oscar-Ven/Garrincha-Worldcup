# GARRINCHA World Cup Prediction App - Environment Variables
#
# Real database = Supabase PostgreSQL only.
# No Docker, no local PostgreSQL, no SQLite, no localhost database URLs.
# Do not commit real secrets.

# Supabase
# Vercel/serverless runtime must use the Supabase Transaction Pooler URL.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Prisma migrations use the Supabase direct database URL.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Auth
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# App
NEXT_PUBLIC_APP_NAME="GARRINCHA World Cup"
NEXT_PUBLIC_APP_URL="https://worldcup.garrincha.be"
APP_PREVIEW_MODE="false"
NEXT_PUBLIC_DEMO_MODE="false"

# Owner account (seed)
OWNER_EMAIL="wc.garrincha@gmail.com"
OWNER_DISPLAY_NAME="GARRINCHA"
OWNER_PASSWORD="replace-with-owner-password"
OWNER_PHONE=""

# Email provider (Resend)
RESEND_API_KEY="replace-with-resend-api-key"
EMAIL_FROM="Garrincha World Cup Predictions <noreply@garrincha.be>"

# Upstash Redis (production rate limiting)
UPSTASH_REDIS_REST_URL="https://replace-with-upstash-rest-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-rest-token"

# Debug (development only — enables /api/debug/db-url diagnostic endpoint)
# DEBUG_DB_DIAGNOSTIC="true"

# Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN="https://replace@o000000.ingest.de.sentry.io/000000"
SENTRY_DSN="https://replace@o000000.ingest.de.sentry.io/000000"
SENTRY_ORG="garrincha-worldcup"
SENTRY_PROJECT="garrincha-worldcup"
SENTRY_AUTH_TOKEN="replace-with-sentry-auth-token"

# Football data provider
FOOTBALL_DATA_PROVIDER="api-football"
FOOTBALL_DATA_COMPETITION_CODE="1"
FOOTBALL_DATA_SEASON="2026"
FOOTBALL_DATA_API_KEY="replace-with-api-football-key"

# Cron (Vercel cron jobs send this as Authorization: Bearer <secret>)
CRON_SECRET="replace-with-a-long-random-cron-secret"

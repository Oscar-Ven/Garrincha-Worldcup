# ═══════════════════════════════════════════════════════════════════════════════
# GARRINCHA World Cup Prediction App — Environment Variables
#
# CLOUD-ONLY SETUP.  Real database = Supabase PostgreSQL only.
# No Docker. No local PostgreSQL. No SQLite. No localhost database URLs.
#
# For local development without Supabase:
#   Set APP_PREVIEW_MODE=true (UI/demo review only — no real database writes).
#
# For local development WITH Supabase:
#   Use real Supabase connection strings below — never localhost URLs.
#
# NEVER commit this file with real secrets filled in.
# NEVER paste real secrets into chat, email, or public channels.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────────────────────
#
# DATABASE_URL — Supabase direct connection for Render (persistent Node.js process).
#   On Render, use the direct URL for both DATABASE_URL and DIRECT_URL.
#   No Transaction Pooler needed — Render holds a persistent connection.
#   Get from: Supabase Dashboard → Project → Connect → Direct connection
#
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

#
# DIRECT_URL — Supabase direct database URL for Prisma migrations.
#   Same as DATABASE_URL on Render. Keep separate in case you need to
#   point migrations to a different connection in future.
#
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Auth ──────────────────────────────────────────────────────────────────────
#
# JWT_SECRET — HS256 signing secret for session cookies.
#   Minimum 32 characters. Use a strong random value.
#   Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="GARRINCHA World Cup"

# Production URL — used for permanent access-link emails and metadata.
# Set to https://[YOUR-APP-DOMAIN] for production.
# Set to http://localhost:3000 only for local development (not in Vercel env).
NEXT_PUBLIC_APP_URL="https://[YOUR-APP-DOMAIN]"

# Preview / demo mode — set true ONLY for local UI design review without a database.
# Must be false for Supabase testing and production.
APP_PREVIEW_MODE="false"
NEXT_PUBLIC_DEMO_MODE="false"

# ─── Seeded admin accounts ────────────────────────────────────────────────────
# Created by npm run db:seed. Do not commit real passwords.
# Owner/Super Admin — defaults to wc.garrincha@gmail.com if OWNER_EMAIL is not set.
OWNER_EMAIL="wc.garrincha@gmail.com"
OWNER_DISPLAY_NAME="GARRINCHA"
OWNER_PASSWORD="replace-with-owner-password"
ADMIN_PASSWORD="replace-with-admin-password"

# Center admin accounts — one per GARRINCHA Center (10 accounts).
# All 10 share this password initially. Replace with unique credentials before public launch.
# Run npm run db:seed AFTER applying migration 20260604000000_center_admin_role.
CENTER_ADMIN_PASSWORD="replace-with-center-admin-password"

# ─── Email provider (Resend) ──────────────────────────────────────────────────
#
# Required for permanent player access-link emails.
# Without these vars the app skips email delivery and logs a warning — it does NOT throw.
#
# Setup:
#   1. Register at https://resend.com
#   2. Add domain [your-domain.com] → add SPF, DKIM, DMARC DNS records
#   3. Wait for domain verification (minutes to a few hours)
#   4. Create an API key in the Resend dashboard
#   5. Set both values below
#
# EMAIL_FROM format: "Display Name <address@domain.com>"
# The display name "Garrincha World Cup Predictions" is what shows in the inbox.
#
RESEND_API_KEY="replace-with-resend-api-key"
# Final production value — requires garrincha.be verified in Resend.
# Temporary testing only: use EMAIL_FROM="onboarding@resend.dev"
EMAIL_FROM="Garrincha World Cup Predictions <noreply@garrincha.be>"

# ─── Upstash Redis (production rate limiting) ─────────────────────────────────
#
# When both vars are set, checkRateLimit uses Upstash Redis fixed-window counters
# instead of the in-memory fallback. This is required for multi-instance production.
# Without these vars the app falls back to in-memory rate limiting automatically.
#
UPSTASH_REDIS_REST_URL="https://replace-with-upstash-rest-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-rest-token"
REDIS_URL="rediss://default:replace-with-redis-password@replace-with-host.upstash.io:6379"

# ─── Monitoring (Sentry) ──────────────────────────────────────────────────────
# Project: garrincha-worldcup | Region: de.sentry.io (EU)
# NEXT_PUBLIC_SENTRY_DSN is embedded in browser bundles — safe to expose.
# SENTRY_DSN is server-only — keep encrypted.
# SENTRY_AUTH_TOKEN is for source map upload during builds — keep secret.
NEXT_PUBLIC_SENTRY_DSN="https://replace@o000000.ingest.de.sentry.io/000000"
SENTRY_DSN="https://replace@o000000.ingest.de.sentry.io/000000"
SENTRY_ORG="garrincha-worldcup"
SENTRY_PROJECT="garrincha-worldcup"
SENTRY_AUTH_TOKEN="replace-with-sentry-auth-token"

# ─── Football data provider (optional future feature) ─────────────────────────
# Server-side only. Do not expose this key in the browser.
# Used for future fixture/result sync. Requires admin confirmation before score recalculation.
FOOTBALL_DATA_PROVIDER="football-data.org"
FOOTBALL_DATA_COMPETITION_CODE="WC"
FOOTBALL_DATA_SEASON="2026"
FOOTBALL_DATA_API_KEY="replace-with-football-data-api-key"
